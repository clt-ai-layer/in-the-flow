# AI Provider: kimi | gemini (defaults to kimi)
AI_PROVIDER=kimi

# Optional model override (defaults: kimi-k2.6 for Kimi, gemini-2.0-flash for Gemini)
# AI_MODEL=kimi-k2.6

# Moonshot Kimi API Key (when AI_PROVIDER=kimi)
# Get your key at: https://platform.moonshot.cn/
KIMI_API_KEY=your-kimi-api-key-here

# Google Gemini API Key (when AI_PROVIDER=gemini)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# MongoDB connection (read automatically from this file on backend startup)
MONGODB_URI=mongodb://localhost:27017

# Server port (optional, defaults to 8000)
# PORT=8000
